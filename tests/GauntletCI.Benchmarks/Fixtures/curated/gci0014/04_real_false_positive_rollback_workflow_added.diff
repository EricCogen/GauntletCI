# origin: real
# source: https://github.com/activepieces/activepieces/pull/12344
# expected: do-not-fire
# reason: Adds explicit breaking-migration checks and a dedicated rollback workflow with migration manifest support, improving rollback safety.

diff --git a/.github/workflows/continuous-delivery-release.yml b/.github/workflows/continuous-delivery-release.yml
index 3c357043c97..abd121378c6 100644
--- a/.github/workflows/continuous-delivery-release.yml
+++ b/.github/workflows/continuous-delivery-release.yml
@@ -69,3 +69,25 @@ jobs:
              activepieces/activepieces:latest
              ghcr.io/activepieces/activepieces:${{ steps.version.outputs.release }}
              ghcr.io/activepieces/activepieces:latest
+
+      - name: Check for breaking migrations
+        id: migration-check
+        run: npx tsx tools/scripts/check-release-migrations.ts ${{ steps.version.outputs.release }}
+
+      - name: Add breaking migration note to release
+        if: steps.migration-check.outputs.has_breaking == 'true'
+        run: |
+          VERSION=${{ steps.version.outputs.release }}
+          BODY=$(gh release view "$VERSION" --json body -q .body)
+          NOTE=$(cat <<EOF
+          > **Note:** This release includes database changes that can't be automatically rolled back (${{ steps.migration-check.outputs.breaking_names }}).
+          EOF
+          )
+          gh release edit "$VERSION" --notes "${BODY}${NOTE}"
diff --git a/.github/workflows/continuous-delivery-rollback.yml b/.github/workflows/continuous-delivery-rollback.yml
new file mode 100644
index 00000000000..d9c20007d8b
--- /dev/null
+++ b/.github/workflows/continuous-delivery-rollback.yml
@@ -0,0 +1,63 @@
+name: Continuous Delivery — Rollback
+on:
+  workflow_dispatch:
+    inputs:
+      rollback_to_image_tag:
+        description: 'Image tag to roll back TO (e.g. 0.51.0.abc1234.beta)'
+        required: true
+      force:
+        description: 'Force rollback even if breaking migrations exist'
+        type: boolean
+        default: false
+jobs:
+  rollback:
+      - name: Rollback DB migrations
+        run: |
+          MANIFEST='${{ steps.manifest.outputs.json }}'
+          ssh ops -t -t "bash -ic \"cd mrsk/prod && kamal app exec --config-file=config/app.yml -- \
+            node /usr/src/app/packages/server/api/dist/src/rollback.js \
+            --manifest '$MANIFEST' $FORCE_FLAG ; exit\""
