# origin: real
# source: https://github.com/mastodon/mastodon/pull/36000
# expected: do-not-fire
# reason: Only a noisy debug log in a hot middleware loop is removed; the error-level rescue log with request context is preserved, so observability is not degraded.

--- a/app/middleware/request_tracker_middleware.rb
+++ b/app/middleware/request_tracker_middleware.rb
@@ -14,18 +14,12 @@ class RequestTrackerMiddleware
   def call(env)
     request    = ActionDispatch::Request.new(env)
     request_id = env['action_dispatch.request_id'] || SecureRandom.hex(8)
 
-    Rails.logger.debug(
-      "RequestTracker: processing request",
-      path:       request.fullpath,
-      method:     request.method,
-      request_id: request_id,
-    )
-
     status, headers, body = @app.call(env)
     [status, headers, body]
   rescue => e
     Rails.logger.error(
       "RequestTracker: unhandled error in middleware",
+      request_id: request_id,
       path:       request.fullpath,
       error:      e.message,
       backtrace:  e.backtrace&.first(3),
