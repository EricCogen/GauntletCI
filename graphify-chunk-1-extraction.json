    {
      "id": "IRule",
      "label": "IRule Interface",
      "file_type": "interface",
      "source_file": "src/GauntletCI.Core/Rules/IRule.cs",
      "source_location": "1-24",
      "rationale": "Core contract for all rule implementations: defines async EvaluateAsync method and Id/Name properties. Auto-discovered via reflection."
    },
    {
      "id": "RuleBase",
      "label": "RuleBase Abstract Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/RuleBase.cs",
      "source_location": "1-80",
      "rationale": "Abstract base providing CreateFinding helper overloads (file-level and diff-wide findings). Eliminates boilerplate across all rule implementations."
    },
    {
      "id": "GCI0001_DiffIntegrity",
      "label": "GCI0001: Diff Integrity",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0001_DiffIntegrity.cs",
      "source_location": "13-102",
      "rationale": "Detects mixed scope (code+non-code) and excessive formatting churn. Uses lock-file filters and whitespace ratio heuristics. Foundational rule for PR quality."
    },
    {
      "id": "GCI0003_BehavioralChangeDetection",
      "label": "GCI0003: Behavioral Change Detection",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0003_BehavioralChangeDetection.cs",
      "source_location": "1-100",
      "rationale": "Detects removed logic, method signature changes, and cryptographic boundary changes. Uses context analyzer for confidence boosts (security paths, commit messages, test signals). Narrows false positives by avoiding common control-flow keywords."
    },
    {
      "id": "GCI0004_BreakingChangeRisk",
      "label": "GCI0004: Breaking Change Risk",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0004_BreakingChangeRisk.cs",
      "source_location": "16-110",
      "rationale": "Specialized on [Obsolete] attribute transitions. Corpus analysis showed reduction from 117 FPs; now focuses on [Obsolete] add/remove only. Guards against premature deprecation removal."
    },
    {
      "id": "GCI0006_EdgeCaseHandling",
      "label": "GCI0006: Edge Case Handling",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0006_EdgeCaseHandling.cs",
      "source_location": "16-100",
      "rationale": "Detects null dereferences (.Value access), missing parameter validation, and loop boundary changes. Rich guard patterns: LINQ mapping, IOptions<T>, KeyValuePair, expression-bodied members, NRT-aware Nullable<T> analysis."
    },
    {
      "id": "GCI0007_ErrorHandlingIntegrity",
      "label": "GCI0007: Error Handling Integrity",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0007_ErrorHandlingIntegrity.cs",
      "source_location": "13-282",
      "rationale": "Detects swallowed exceptions (empty catch bodies), removed error logs from error contexts, and throw statement removal. Uses structured log method patterns (distinct from bare keywords). Integrates Roslyn CA1031 diagnostics."
    },
    {
      "id": "GCI0010_HardcodingAndConfiguration",
      "label": "GCI0010: Hardcoding and Configuration",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0010_HardcodingAndConfiguration.cs",
      "source_location": "17-80",
      "rationale": "Detects hardcoded IPs, URLs, connection strings, ports, environment names. Uses regex (HardcodedUrlRegex, BareIpAddressRegex) with safe-list (docs.microsoft, github.com, example.com). Excludes credentials (deferred to GCI0012)."
    },
    {
      "id": "GCI0012_SecurityRisk",
      "label": "GCI0012: Security Risk",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0012_SecurityRisk.cs",
      "source_location": "17-80",
      "rationale": "Detects SQL injection, weak crypto (MD5, SHA1, DES, RC2), dangerous APIs (Assembly.Load, Activator.CreateInstance), hardcoded credentials. Owns credential detection (includes pwd, token). Boundary: skips log calls to defer to GCI0029."
    },
    {
      "id": "GCI0015_DataIntegrityRisk",
      "label": "GCI0015: Data Integrity Risk",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0015_DataIntegrityRisk.cs",
      "source_location": "13-80",
      "rationale": "Detects mass assignment without allowlist, unsafe HTTP input binding, unchecked casts, SQL IGNORE patterns. Uses DataIntegrityPatterns for HTTP context signal detection."
    },
    {
      "id": "GCI0020_ResourceExhaustionPatterns",
      "label": "GCI0020: Resource Exhaustion Pattern Detection",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0020_ResourceExhaustionPatterns.cs",
      "source_location": "18-80",
      "rationale": "Detects timeout removal, iteration limit removal, unbounded resource increases, resource cleanup removal, unbounded async operations. Uses pattern arrays from DomainSpecificPatterns (timeout, iteration, resource, async patterns)."
    },
    {
      "id": "WellKnownPatterns",
      "label": "WellKnownPatterns Facade",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/WellKnownPatterns.cs",
      "source_location": "1-100",
      "rationale": "Centralized facade delegating to 5 domain-specific pattern classes. Eliminates guard pattern duplication. Module-level constants: SecretNamePatterns, HighSeverityLogKeywords. Backward-compatible delegation."
    },
    {
      "id": "FileContextPatterns",
      "label": "FileContextPatterns Domain Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Patterns/FileContextPatterns.cs",
      "source_location": "18-80",
      "rationale": "Test/spec file detection (word-boundary test, PascalCase Tests/Benchmark suffixes, /spec /specs dirs), generated file detection, infrastructure file detection (Program.cs, Startup.cs). Used by all rules for false-positive suppression."
    },
    {
      "id": "HttpExternalServicePatterns",
      "label": "HttpExternalServicePatterns Domain Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Patterns/HttpExternalServicePatterns.cs",
      "source_location": "18-80",
      "rationale": "gRPC vs HTTP client framework guards. Detects IHttpClientFactory (factory-managed timeout), GrpcChannel/ChannelOptions, Polly policies. Used by GCI0039 to reduce false positives."
    },
    {
      "id": "SecurityPatterns",
      "label": "SecurityPatterns Domain Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Patterns/SecurityPatterns.cs",
      "source_location": "19-80",
      "rationale": "Credential detection helpers: isEnvVarName, isBenignLiteralValue, hasAssignment, findAssignmentIndex. Skips string literals and lambda expressions. Used by GCI0010, GCI0012."
    },
    {
      "id": "NullabilityPatterns",
      "label": "NullabilityPatterns Domain Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Patterns/NullabilityPatterns.cs",
      "source_location": "18-80",
      "rationale": "NRT (Nullable Reference Type) detection: #nullable directives, modern C# heuristics (record, init, required), regex pattern for non-nullable string params. Used by GCI0006, GCI0043."
    },
    {
      "id": "DomainSpecificPatterns",
      "label": "DomainSpecificPatterns Domain Class",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Patterns/DomainSpecificPatterns.cs",
      "source_location": "19-100",
      "rationale": "7 pattern domains: TimeoutPatterns, IterationLimitPatterns, ResourceLimitPatterns, ResourceCleanupPatterns, AsyncPatterns, TestSilencePatterns, TestAttributeMarkers, TestAssertionKeywords."
    },
    {
      "id": "BehavioralChangeContextAnalyzer",
      "label": "BehavioralChangeContextAnalyzer Helper",
      "file_type": "code",
      "source_file": "src/GauntletCI.Core/Rules/Implementations/GCI0003_BehavioralChangeDetection.cs",
      "source_location": "13-47",
      "rationale": "Computes confidence boosts for behavioral changes: security-critical file paths (+0.20), security keywords in commit message (+0.15), test changes with security patterns (+0.15). Capped at +0.50."
    }
