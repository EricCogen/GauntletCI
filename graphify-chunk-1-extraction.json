    },
    {
      "id": "pattern_consolidation_architecture",
      "label": "Pattern Consolidation Architecture",
      "members": ["WellKnownPatterns", "FileContextPatterns", "HttpExternalServicePatterns", "SecurityPatterns", "NullabilityPatterns", "DomainSpecificPatterns"],
