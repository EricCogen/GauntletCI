      "members": ["GCI0010_HardcodingAndConfiguration", "GCI0012_SecurityRisk", "GCI0015_DataIntegrityRisk"],
      "rationale": "GCI0010 detects hardcoded IPs/URLs (excludes credentials), GCI0012 owns credential detection and SQL injection, GCI0015 detects mass-assignment and unsafe input binding. Together they secure data boundaries."
    },
    {
      "id": "resilience_rules_cluster",
      "label": "Resilience and Error Handling",
      "members": ["GCI0007_ErrorHandlingIntegrity", "GCI0020_ResourceExhaustionPatterns"],
