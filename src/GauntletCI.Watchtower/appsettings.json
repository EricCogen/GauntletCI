{
  "Database": {
    "Path": "watchtower.db"
  },
  "GauntletCI": {
    "RepositoryUrl": "https://github.com/EricCogen/GauntletCI.git",
    "RepositoryPath": "./gauntletci-repo",
    "Branch": "main",
    "PublishPath": "./gauntletci-build/cli"
  },
  "SecurityFeeds": [
    {
      "Name": "NVD",
      "Url": "https://services.nvd.nist.gov/rest/json/cves/2.0",
      "Type": "NVD",
      "Enabled": true,
      "PollingIntervalHours": 24
    },
    {
      "Name": "GitHub Advisory Database",
      "Url": "https://github.com/advisories",
      "Type": "GHSA",
      "Enabled": true,
      "PollingIntervalHours": 24
    }
  ],
  "Validation": {
    "TimeoutSeconds": 300,
    "SandboxPath": "./sandbox",
    "DiffMaxSizeBytes": 5242880
  },
  "Publishing": {
    "ArticlesOutputPath": "./articles",
    "SiteRepositoryPath": "../../../site",
    "SiteBlogPath": "app/blog"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/watchtower-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
