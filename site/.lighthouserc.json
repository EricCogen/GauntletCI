{
  "ci": {
    "collect": {
      "startServerCommand": "npx --yes serve out -l 9009",
      "startServerReadyPattern": "Accepting connections",
      "url": [
        "http://localhost:9009/",
        "http://localhost:9009/about",
        "http://localhost:9009/articles",
        "http://localhost:9009/docs",
        "http://localhost:9009/pricing",
        "http://localhost:9009/benchmark",
        "http://localhost:9009/articles/why-tests-miss-bugs",
        "http://localhost:9009/articles/why-code-review-misses-bugs",
        "http://localhost:9009/articles/what-is-diff-based-analysis",
        "http://localhost:9009/articles/detect-breaking-changes-before-merge",
        "http://localhost:9009/articles/can-ai-code-review-be-deterministic",
        "http://localhost:9009/articles/behavioral-change-risk-formal-framework",
        "http://localhost:9009/articles/case-studies",
        "http://localhost:9009/articles/the-asymmetry-of-change"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
